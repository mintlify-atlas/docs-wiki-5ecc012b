  "keyFeatures": [
    "fineract-provider — Spring Boot application assembly, ServerApplication entry point, application.properties, COB loan steps, hooks, campaigns, credit bureau, surveys, SPM, templates",
    "fineract-core — shared kernel: infrastructure.core (boot, config, API plumbing, serialization, exceptions, JPA), commands, batch API, jobs API, event framework, useradministration, organisation, portfolio base packages",
    "fineract-security — tenant-aware authentication filters, basic auth, OAuth2, two-factor, platform security context",
    "fineract-loan — loan domain model, transaction processors, schedule generators, delinquency, reschedule, guarantors",
    "fineract-progressive-loan + fineract-progressive-loan-embeddable-schedule-generator — progressive loan schedule engine",
    "fineract-loan-origination — loan originator module",
    "fineract-working-capital-loan — working capital loan product, breach detection, COB",
    "fineract-savings — savings, fixed deposit, recurring deposit accounts and interest rate charts",
    "fineract-accounting — GL accounts, journal entries, accruals, closures, trial balance, rules, provisioning",
    "fineract-investor — external asset owner transfers, investor accounting, delayed settlement",
    "fineract-branch — tellers and cashiers (organisation.teller)",
    "fineract-charge, fineract-tax, fineract-rates — charges, tax components/groups, floating rates",
    "fineract-document — document management and content stores (filesystem/S3)",
    "fineract-report — report engine (infrastructure.report)",
    "fineract-mix — MIX taxonomy/XBRL reporting",
    "fineract-cob — generic close-of-business batch framework: business steps, partitioning, tasklets, locking",
    "fineract-command + jdbc/async/disruptor/audit variants — next-gen command dispatch framework",
    "fineract-validation — bean validation constraints",
    "fineract-avro-schemas — Avro schemas for external events (loan, savings, client, etc.)",
    "fineract-client / fineract-client-feign — generated Java SDKs (Retrofit and Feign)",
    "fineract-db — tenant first-time install SQL",
    "fineract-war — WAR packaging",
    "integration-tests, twofactor-tests, oauth2-tests — Java integration test suites",
    "fineract-e2e-tests-core / fineract-e2e-tests-runner — Cucumber/Gherkin E2E suites",
    "custom/ — dynamically discovered custom module pattern (custom/acme examples, custom docker image)",
    "buildSrc — FineractPlugin Gradle release tooling (Jira, Confluence, GPG, SVN services)",
    "docker-compose files for MariaDB/MySQL/PostgreSQL/ActiveMQ/Kafka/OAuth2/two-factor variants",
    "kubernetes/ — deployment manifests",
    "Multi-tenant architecture with tenant store + per-tenant Liquibase migrations",
    "Maker-checker command pipeline with audit (m_portfolio_command_source)",
    "Spring Batch remote partitioning for LOAN_COB via JMS/Kafka/Spring events",
    "External event publishing with Avro serialization to Kafka/JMS"
  ],
  "publicApiSurface": [
    "org.apache.fineract.ServerApplication (fineract-provider) — Spring Boot entry point",
    "165 JAX-RS *ApiResource classes under /api/v1 (LoansApiResource, ClientsApiResource, SavingsAccountsApiResource, JournalEntriesApiResource, UsersApiResource, ...)",
    "AuthenticationApiResource — POST /authentication",
    "BatchApiResource — POST /batches",
    "CommandWrapperBuilder + PortfolioCommandSourceWritePlatformService — command write path",
    "SchedulerJobApiResource / InlineJobApiResource — job management endpoints",
    "InteropApiResource — Mojaloop-style interoperation API",
    "RunreportsApiResource / DatatablesApiResource — reporting and dynamic data tables",
    "fineract-client FineractClient (Retrofit SDK), fineract-client-feign (Feign SDK)",
    "fineract-avro-schemas *.avsc — external event payload contracts",
    "application.properties FINERACT_* environment variables",
    "docker-compose.yml / kubernetes manifests — deployment entry points"
  ]
}
